# 服务端口
PORT=9001

# 数据源由 basic 统一分配
BASIC_SERVICE_URL=http://127.0.0.1:9002
SERVICE_ID=auth
INTERNAL_API_SECRET=mono-repo-internal-dev
DATASOURCE_NOTIFY_PREFIX=mono:service-datasource:

# JWT 密钥（生产环境务必修改）
JWT_SECRET=mono-repo-dev-secret-change-me

# Cookie 配置
COOKIE_NAME=mono_token
COOKIE_MAX_AGE=604800

# Redis 会话 + 数据源变更订阅
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
SESSION_PREFIX=mono:session:

# 跨域（开发环境主应用地址）
CORS_ORIGIN=http://localhost:3000

# 默认管理员（首次启动自动创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=123zhangbei

