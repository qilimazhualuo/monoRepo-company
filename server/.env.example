# 单体服务端口（与 apps/main vite 代理 /api → 9001 一致）
PORT=9001

# 静态资源目录（yarn build 后由 server 托管 dist，开发时仍走 vite）
PUBLIC_DIR=../dist
PUBLIC_ENABLED=true

# 数据库类型: pg | mysql（改 DB_DRIVER 后重启生效）
DB_DRIVER=pg

# PostgreSQL（docker compose 默认密码 123zhangbei）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123zhangbei
DB_NAME=mono_repo

# MySQL（DB_DRIVER=mysql 时启用，注释掉上方 PostgreSQL 块）
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=123zhangbei
# DB_NAME=mono_repo
# JWT 密钥（生产环境务必修改）
JWT_SECRET=mono-repo-dev-secret-change-me

# Cookie 配置
COOKIE_NAME=mono_token
COOKIE_MAX_AGE=604800

# Redis 会话（鉴权 token 存 Redis，logout 可立即失效）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
SESSION_PREFIX=mono:session:

# 默认管理员（首次启动自动创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# RSA 密钥（登录密码 RSA-OAEP 加密，单行 PEM，换行用 \n）
# 未配置时启动会临时生成并在控制台打印，建议复制到此处固定
RSA_PUBLIC_KEY=""
RSA_PRIVATE_KEY=""
