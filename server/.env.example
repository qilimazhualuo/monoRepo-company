# 服务端口
PORT=9001

# 静态资源目录（默认 monorepo 根目录 dist，需先 yarn build）
# PUBLIC_DIR=../dist
# PUBLIC_ENABLED=true

# 数据库类型: pg | mysql
DB_DRIVER=pg

# PostgreSQL 示例
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mono_repo

# MySQL 示例（DB_DRIVER=mysql 时使用）
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=mono_repo

# JWT 密钥（生产环境务必修改）
JWT_SECRET=mono-repo-dev-secret-change-me

# Cookie 配置
COOKIE_NAME=mono_token
COOKIE_MAX_AGE=604800

# 跨域（开发环境主应用地址）
CORS_ORIGIN=http://localhost:8080

# 默认管理员（首次启动自动创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# RSA 密钥（登录密码 RSA-OAEP 加密，单行 PEM，换行用 \n）
# 未配置时启动会临时生成并在控制台打印，建议复制到此处固定
RSA_PUBLIC_KEY=""
RSA_PRIVATE_KEY=""
