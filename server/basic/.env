# 服务端口
PORT=9002

# 数据库（仅 basic 自身使用，库名 basic）
DB_DRIVER=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123zhangbei
DB_NAME=basic

# 服务发现
GATEWAY_SERVICE_URL=http://127.0.0.1:9000
AUTH_SERVICE_URL=http://127.0.0.1:9001

# 内部通信 + 数据源变更通知
INTERNAL_API_SECRET=mono-repo-internal-dev
DATASOURCE_NOTIFY_PREFIX=mono:service-datasource:

# Redis（通知各微服务切换数据源）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
SESSION_PREFIX=mono:session:

# 跨域
CORS_ORIGIN=http://localhost:3000

# ---------- Nacos ----------
NACOS_ENABLED=false
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_GROUP=MONO_REPO
NACOS_CONFIG_DATA_ID=basic
NACOS_SERVICE_NAME=basic
NACOS_SERVICE_IP=127.0.0.1
NACOS_USERNAME=admin
NACOS_PASSWORD=123zhangbei
