# 导航服务端口（与 apps/navigation-front vite 代理 /api → 9002 一致）
PORT=9002

# PostgreSQL（建议先 yarn docker:up；库名 navigation）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123zhangbei
DB_NAME=navigation

# 路网表配置（gpkg 导入后按实际表名/字段改）
ROAD_TABLE=roads
ROAD_GEOM_COLUMN=geom
ROAD_ID_COLUMN=id

# 算路：沿起终点连线外扩缓冲区（度），找不到路径会逐步加大到 MAX
ROUTE_BUFFER_DEG=0.15
ROUTE_MAX_BUFFER_DEG=0.8
ROUTE_BUFFER_STEP_DEG=0.15

# 起终点吸附到路网的最大距离（米）
SNAP_TOLERANCE_M=500
