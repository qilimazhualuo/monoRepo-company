{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "jsx": "preserve",
        "jsxImportSource": "vue",
        "noEmit": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}
