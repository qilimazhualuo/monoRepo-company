{
    "name": "mono-repo",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*",
        "plugins/*",
        "server/auth",
        "server/basic",
        "server/gateway"
    ],
    "scripts": {
        "dev": "node scripts/dev.mjs",
        "dev:gateway": "yarn workspace gateway dev",
        "dev:server": "yarn workspace auth dev",
        "dev:basic": "yarn workspace basic dev",
        "dev:main": "yarn workspace main dev",
        "dev:sub": "yarn workspace sub-app dev",
        "dev:basic-app": "yarn workspace basic-app dev",
        "build": "yarn build:all && node scripts/merge-dist.mjs",
        "build:all": "node scripts/build-all.mjs",
        "build:main": "yarn workspace main build",
        "build:sub": "yarn workspace sub-app build",
        "build:basic-app": "yarn workspace basic-app build",
        "analyze": "yarn analyze:main && yarn analyze:sub",
        "analyze:main": "yarn workspace main build --mode analyze",
        "docker:up": "docker compose -p mono-repo -f docker/docker-compose.yml up -d",
        "docker:down": "docker compose -p mono-repo -f docker/docker-compose.yml down",
        "docker:logs": "docker compose -p mono-repo -f docker/docker-compose.yml logs -f"
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "rollup-plugin-visualizer": "^5.14.0"
    },
    "resolutions": {
        "vue": "^3.5.13",
        "vue-router": "^4.5.0",
        "pinia": "^2.3.0",
        "antdv-next": "^1.3.5"
    }
}
