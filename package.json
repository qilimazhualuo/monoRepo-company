{
    "name": "mono-repo",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*",
        "plugins/*",
        "server"
    ],
    "scripts": {
        "dev": "concurrently -n server,main,sub -c magenta,blue,green \"yarn dev:server\" \"yarn dev:main\" \"yarn dev:sub\"",
        "dev:packages": "concurrently -n utils,page,ui,basic \"yarn workspace wc-utils build --watch\" \"yarn workspace wc-page build --watch\" \"yarn workspace wc-ui build --watch\" \"yarn workspace wc-basic build --watch\"",
        "dev:server": "yarn workspace server dev",
        "dev:main": "yarn workspace main dev",
        "dev:sub": "yarn workspace sub-app dev",
        "build:packages": "node scripts/build-packages.mjs",
        "build": "yarn build:packages && yarn build:all && node scripts/merge-dist.mjs",
        "build:all": "node scripts/build-all.mjs",
        "build:main": "yarn workspace main build",
        "build:sub": "yarn workspace sub-app build",
        "analyze": "yarn analyze:main && yarn analyze:sub",
        "analyze:main": "yarn workspace main build --mode analyze",
        "analyze:sub": "yarn workspace sub-app build --mode analyze",
        "docker:up": "docker compose -f docker/docker-compose.yml up -d",
        "docker:down": "docker compose -f docker/docker-compose.yml down",
        "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
    },
    "devDependencies": {
        "@antdv-next/auto-import-resolver": "^1.0.2",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vitejs/plugin-vue-jsx": "^4.1.2",
        "concurrently": "^9.1.2",
        "less": "^4.2.1",
        "rollup-plugin-visualizer": "^5.14.0",
        "typescript": "~5.7.2",
        "unplugin-vue-components": "^28.0.0",
        "vite": "^6.0.5",
        "vite-plugin-dts": "^4.5.0",
        "vue-tsc": "^2.2.0"
    },
    "resolutions": {
        "vue": "^3.5.13",
        "vue-router": "^4.5.0",
        "pinia": "^2.3.0",
        "antdv-next": "^1.3.5"
    }
}
