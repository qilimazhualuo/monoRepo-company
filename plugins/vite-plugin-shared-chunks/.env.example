# 自动扫描 CONSUMER_APPS 里各应用的重复依赖并打入 shared（默认开启）
# workspace 包（wc-ui 等）由 apps 依赖引入，无需单独扫描 packages/
# 如需额外强制共享某些包，取消下行注释（逗号分隔）
# PACKAGES=wc-ui,wc-utils

# 参与扫描的应用（相对 apps/）
CONSUMER_APPS=main,sub-app

# 共享 chunk 路径前缀名（实际目录为 shared-{buildId}/，构建时写入各 JS）
# PUBLIC_PATH=/shared/  →  /shared-a1b2c3d4/vue.js
PUBLIC_PATH=/shared/
